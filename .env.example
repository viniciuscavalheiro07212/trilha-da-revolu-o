VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publica-ou-anon-key

# Variaveis apenas do servidor. Nunca use prefixo VITE_ nelas.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-ou-token-de-producao
MERCADO_PAGO_ENV=production
MERCADO_PAGO_TEST_PAYER_EMAIL=test_user_br@testuser.com
MERCADO_PAGO_WEBHOOK_SECRET=secret-gerado-no-painel-de-webhooks
MERCADO_PAGO_PIX_AMOUNT=100
MERCADO_PAGO_PIX_EXPIRATION=PT30M

# Segredos da Edge Function send-voucher-emails no Supabase.
# Cadastre-os em Project Settings > Edge Functions > Secrets.
RESEND_API_KEY=re_xxxxxxxxx
VOUCHER_EMAIL_FROM="VIII Trilha da Revolucao <voucher@seudominio.com>"
VOUCHER_EMAIL_REPLY_TO=contato@seudominio.com
SITE_URL=https://seu-dominio.com
# Conta Google autorizada a disparar o email de demonstracao.
VOUCHER_EMAIL_TEST_RECIPIENT=seu-email-da-conta-resend@exemplo.com
